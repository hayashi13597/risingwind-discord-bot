# Discord
DISCORD_TOKEN=your_primary_bot_token_here
DISCORD_TOKEN_2=your_secondary_bot_token_here

# Poll
POLL_CHANNEL_ID=123456789012345678
POLL_TIMEZONE=Asia/Bangkok
# Auto poll schedule: cron expression (default: every Monday 00:01)
POLL_CRON=1 0 * * 1

# Scheduled @everyone ping
PING_CHANNEL_ID=123456789012345678
PING_TIMEZONE=Asia/Bangkok
PING_TIMES=20:00
# Mon=0 … Sun=6 (comma-separated). Default: Mon-Fri
PING_WEEKDAYS=0,1,2,3,4
# Optional: override default ping message
# PING_MESSAGE=Your custom message here